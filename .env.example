# ══════════════════════════════════════════════════════════════════════════════
# NSE Options Trader — Environment Configuration Template
# Copy this file to .env and fill in your secrets.
# ══════════════════════════════════════════════════════════════════════════════

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development                     # development | production
TRADING_MODE=paper                      # paper | live  (MUST be 'paper' to start)
LOG_LEVEL=INFO

# ── Dhan Broker API ───────────────────────────────────────────────────────────
DHAN_CLIENT_ID=fec5ea65
DHAN_ACCESS_TOKEN=d695ffdb-8721-4c27-8e32-18e95124d252

# ── Google Gemini (LLM) ───────────────────────────────────────────────────────
GOOGLE_API_KEY=AIzaSyAF8VC111rq4WK8UIe3avyo-3im4rvsgzE
GEMINI_MODEL=gemini-1.5-pro

# ── PostgreSQL / TimescaleDB ──────────────────────────────────────────────────
POSTGRES_USER=trader
POSTGRES_PASSWORD=trader_secret
POSTGRES_DB=nse_options
POSTGRES_HOST=timescaledb
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://trader:trader_secret@timescaledb:5432/nse_options

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret
REDIS_URL=redis://:redis_secret@redis:6379/0

# ── Capital & Risk (INR) ──────────────────────────────────────────────────────
TOTAL_CAPITAL=500000                    # Total capital in INR
MAX_RISK_PER_TRADE_PCT=2.0             # Max % of capital to risk per trade
MAX_DAILY_LOSS_PCT=5.0                 # Circuit breaker: halt if daily loss > X%
MAX_OPEN_POSITIONS=5                   # Maximum concurrent open positions
MAX_POSITION_SIZE_PCT=20.0             # Max single position as % of capital

# ── Notifications ─────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# ── Sentry (optional) ─────────────────────────────────────────────────────────
SENTRY_DSN=

# ── API ───────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
SECRET_KEY=change_this_to_a_secure_random_string_32chars
